{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "gaal: sync (sandbox)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "args": [
        "--config", "${workspaceFolder}/example.gaal.yaml",
        "--sandbox", "${workspaceFolder}/.sandbox",
        "--log-file", "${workspaceFolder}/.sandbox/gaal.log",
        "--verbose",
        "sync"
      ],
      "env": {},
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "gaal: status (sandbox)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "args": [
        "--config", "${workspaceFolder}/example.gaal.yaml",
        "--sandbox", "${workspaceFolder}/.sandbox",
        "--log-file", "${workspaceFolder}/.sandbox/gaal.log",
        //"--verbose",
        "status"
      ],
      "env": {},
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "gaal: service (sandbox, 30s)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "args": [
        "--config", "${workspaceFolder}/example.gaal.yaml",
        "--sandbox", "${workspaceFolder}/.sandbox",
        "--log-file", "${workspaceFolder}/.sandbox/gaal.log",
        "--verbose",
        "--service",
        "--interval", "30s"
      ],
      "env": {},
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "gaal: info repo (sandbox)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "args": [
        "--config", "${workspaceFolder}/example.gaal.yaml",
        "--sandbox", "${workspaceFolder}/.sandbox",
        "--log-file", "${workspaceFolder}/.sandbox/gaal.log",
        //"--verbose",
        "info", "repo"
      ],
      "env": {},
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "gaal: info skill (sandbox)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "args": [
        "--config", "${workspaceFolder}/example.gaal.yaml",
        "--sandbox", "${workspaceFolder}/.sandbox",
        "--log-file", "${workspaceFolder}/.sandbox/gaal.log",
        "--verbose",
        "info", "skill"
      ],
      "env": {},
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "gaal: info mcp (sandbox)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "args": [
        "--config", "${workspaceFolder}/example.gaal.yaml",
        "--sandbox", "${workspaceFolder}/.sandbox",
        "--log-file", "${workspaceFolder}/.sandbox/gaal.log",
        //"--verbose",
        "info", "mcp"
      ],
      "env": {},
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "gaal: version",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "args": ["version"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ]
}
