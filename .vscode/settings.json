{
  "chat.tools.terminal.autoApprove": {
    "go": true,
    "echo": true,
    "make": true,
    "cd": true,
    "grep": true,
    "ls": true,
    "cat": true,
    "pwd": true,
    "mkdir": true,
    "cp": true,
    "mv": true,
    "touch": true,
    "head": true,
    "tail": true,
    "find": true,
    "xargs": true,
    "which": true,
    "unset": true,
    "alias": true,
    "unalias": true,
    "source": true,
    "history": true,
    "clear": true,
    "gofmt": true,
    "gh issue view": true
  },
  "makefile.configureOnOpen": false,
  "yaml.schemas": {
    "./dist/schema.json": ["gaal.yaml", "*.gaal.yaml", ".gaal.yaml"]
  },
  "[markdown]": {
    "editor.defaultFormatter": "davidanson.vscode-markdownlint"
  }
}